# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── MQTT Broker ───────────────────────────────────────────────
# Gunakan broker lokal (Mosquitto) atau cloud (HiveMQ, EMQX)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=aquasense-backend

# ── Express Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
